# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: Auth admin + storage (Vercel: Production + Preview, niet in client bundle)
SUPABASE_SERVICE_ROLE_KEY=

# Optioneel: AI-chat (zonder key vallen onbekende vragen terug op vaste copy)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optioneel: bucket voor chat-bijlagen (default: chat-attachments)
# NEXT_PUBLIC_CHAT_ATTACHMENTS_BUCKET=chat-attachments
