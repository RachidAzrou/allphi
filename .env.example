# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: Auth admin + storage (Vercel: Production + Preview, niet in client bundle)
SUPABASE_SERVICE_ROLE_KEY=

# Server-only: simple admin API protection (use a long random secret)
ADMIN_API_KEY=

# Optioneel: AI-chat (zonder key vallen onbekende vragen terug op vaste copy)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optioneel: bucket voor chat-bijlagen (default: chat-attachments)
# NEXT_PUBLIC_CHAT_ATTACHMENTS_BUCKET=chat-attachments

# Resend (transactional e-mail). Zonder RESEND_API_KEY valt de
# fleet-manager-mailing terug op een gesimuleerde "sent" zodat dev/staging
# blijft werken. RESEND_FROM_ADDRESS moet gevalideerd zijn in Resend.
RESEND_API_KEY=
RESEND_FROM_ADDRESS="AllPhi <schade@allphi.be>"
# Optioneel: comma-separated lijst van extra BCC-adressen (bv. archief@allphi.be)
RESEND_BCC=
